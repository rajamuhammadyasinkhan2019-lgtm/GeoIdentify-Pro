{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID" },
        "email": { "type": "string", "description": "User email address" },
        "displayName": { "type": "string", "description": "User display name" },
        "photoURL": { "type": "string", "description": "User profile photo URL" },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "User role" }
      },
      "required": ["uid", "email"]
    },
    "Identification": {
      "title": "Identification",
      "description": "A record of a mineral/fossil identification analysis",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "imageUrl": { "type": "string" },
        "type": { "type": "string", "enum": ["thinsection", "handspecimen", "outcrop"], "description": "Type of specimen" },
        "category": { "type": "string", "enum": ["mineral", "pollen", "spore", "fossil", "rock"], "description": "Category of identification" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"], "description": "Moderation status" },
        "geologicalEra": { "type": "string" },
        "geographicOrigin": { "type": "string" },
        "hardness": { "type": "number" },
        "color": { "type": "string" },
        "crystalSystem": { "type": "string" },
        "refractiveIndex": { "type": "number" },
        "morphology": { "type": "string" },
        "context": { "type": "string" },
        "isContribution": { "type": "boolean" },
        "results": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "percentage": { "type": "number" },
              "description": { "type": "string" }
            }
          }
        },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "imageUrl", "results", "timestamp", "status"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "identifications/{id}": {
      "schema": "Identification",
      "description": "Identification records"
    }
  }
}
